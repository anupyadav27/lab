  "consolidation_patterns": {
    "pattern_1_aws_terminology": {
      "description": "Remove AWS service names from Azure functions",
      "examples": {
        "cloudwatch": "monitor",
        "s3": "storage",
        "ebs": "disk",
        "bucket": "account"
      },
      "estimated_impact": "60-70 functions"
    },
    "pattern_2_verbose_names": {
      "description": "Shorten verbose service names",
      "examples": {
        "active_directory": "ad"
      },
      "estimated_impact": "45 functions"
    },
    "pattern_3_encryption_suffixes": {
      "description": "Standardize encryption function suffixes",
      "preferred": "_encryption_enabled",
      "consolidate": ["_default_encryption", "_volume_encryption", "_storage_encrypted"],
      "estimated_impact": "25-30 functions"
    },
    "pattern_4_logging_suffixes": {
      "description": "Standardize logging function suffixes",
      "preferred": "_enabled",
      "consolidate": ["_check", "_status_check", "_is_enabled"],
      "estimated_impact": "20-25 functions"
    },
    "pattern_5_resource_terminology": {
      "description": "Use correct Azure resource names",
      "examples": {
        "sql_instance": "sql_database",
        "functions_function": "functions_app"
      },
      "estimated_impact": "15-20 functions"
    }
  },
  
